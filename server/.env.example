# Core server
PORT=5000
JWT_SECRET=replace-me

# Wappie WhatsApp OTP delivery
WAPPIE_API_URL=https://api.wappie.in/v2/whatsapp/messages/sendDirectly
WAPPIE_API_KEY=your-wappie-api-key
WAPPIE_WHATSAPP_FROM=+919649089089
WAPPIE_OTP_TEMPLATE_NAME=otp_authentication
WAPPIE_OTP_TEMPLATE_LANGUAGE=en
WAPPIE_REPORT_TEMPLATE_NAME=template_marketing_20260401171046
WAPPIE_REPORT_TEMPLATE_LANGUAGE=en
APP_BASE_URL=https://your-docnow-domain.com

# Report storage: S3 only
AWS_S3_BUCKET=your-report-bucket
AWS_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Optional prefix inside the bucket
REPORT_STORAGE_PREFIX=reports
