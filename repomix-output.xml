                            {/* Manager / Admin Panel Links */}
                            {(isManager || isSuperAdmin) && (
                                <div className="p-2 pt-0 border-t border-gray-100 mt-1 md:mt-2 flex md:flex-col gap-2 overflow-x-auto md:overflow-x-visible scrollbar-hide">
