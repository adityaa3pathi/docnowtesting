                    ]
                }
            };
        }

        const ledger = await prisma.walletLedger.findMany({
            where,
            skip: (page - 1) * limit,
            take: limit,
            orderBy: { createdAt: 'desc' },
            include: {
                wallet: {
                    include: {
                        user: { select: { id: true, name: true, mobile: true, email: true } }
